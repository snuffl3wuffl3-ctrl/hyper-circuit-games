<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <title>Mini Game Hub</title>
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <link rel="stylesheet" href="styles.css" />
</head>
<body>
  <header class="topbar">
    <h1>Mini Game Hub</h1>
    <input id="searchInput" type="text" placeholder="Search games..." />
    <select id="categoryFilter">
      <option value="all">All categories</option>
    </select>
  </header>

  <main>
    <section id="gameGrid" class="game-grid"></section>

    <section id="overlay" class="overlay hidden">
      <div class="overlay-content">
        <button id="closeOverlay" class="close-btn">×</button>
        <iframe id="gameFrame" src="" loading="lazy"></iframe>
      </div>
    </section>
  </main>

  <script src="main.js"></script>
</body>
</html>
:root {
  --bg: #050816;
  --card-bg: #111827;
  --accent: #6366f1;
  --text: #f9fafb;
  --muted: #9ca3af;
}

* {
  box-sizing: border-box;
  margin: 0;
  padding: 0;
  font-family: system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
}

body {
  background: radial-gradient(circle at top, #111827 0, #020617 60%);
  color: var(--text);
  min-height: 100vh;
}

.topbar {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: 0.75rem;
  padding: 1rem 1.5rem;
  border-bottom: 1px solid #1f2937;
  background: rgba(15, 23, 42, 0.9);
  backdrop-filter: blur(10px);
  position: sticky;
  top: 0;
  z-index: 10;
}

.topbar h1 {
  font-size: 1.4rem;
  font-weight: 700;
  margin-right: auto;
}

.topbar input,
.topbar select {
  background: #020617;
  border: 1px solid #1f2937;
  color: var(--text);
  padding: 0.4rem 0.6rem;
  border-radius: 0.4rem;
  font-size: 0.9rem;
}

main {
  padding: 1.5rem;
}

.game-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
  gap: 1rem;
}

.game-card {
  background: var(--card-bg);
  border-radius: 0.75rem;
  overflow: hidden;
  box-shadow: 0 10px 25px rgba(0, 0, 0, 0.35);
  cursor: pointer;
  transition: transform 0.15s ease, box-shadow 0.15s ease;
  display: flex;
  flex-direction: column;
}

.game-card:hover {
  transform: translateY(-4px);
  box-shadow: 0 16px 35px rgba(0, 0, 0, 0.5);
}

.game-thumb {
  width: 100%;
  aspect-ratio: 16 / 9;
  background-size: cover;
  background-position: center;
}

.game-body {
  padding: 0.75rem 0.9rem 0.9rem;
}

.game-title {
  font-size: 0.95rem;
  font-weight: 600;
  margin-bottom: 0.25rem;
}

.game-meta {
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-size: 0.75rem;
  color: var(--muted);
}

.category-pill {
  background: rgba(99, 102, 241, 0.15);
  color: var(--accent);
  padding: 0.1rem 0.5rem;
  border-radius: 999px;
}

/* Overlay */

.overlay {
  position: fixed;
  inset: 0;
  background: rgba(15, 23, 42, 0.9);
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 1rem;
}

.overlay.hidden {
  display: none;
}

.overlay-content {
  position: relative;
  width: 100%;
  max-width: 960px;
  aspect-ratio: 16 / 9;
  background: #020617;
  border-radius: 0.75rem;
  overflow: hidden;
  box-shadow: 0 20px 50px rgba(0, 0, 0, 0.7);
}

#gameFrame {
  width: 100%;
  height: 100%;
  border: none;
}

.close-btn {
  position: absolute;
  top: 0.5rem;
  right: 0.5rem;
  border: none;
  background: rgba(15, 23, 42, 0.8);
  color: var(--text);
  width: 32px;
  height: 32px;
  border-radius: 999px;
  cursor: pointer;
  font-size: 1.1rem;
}
