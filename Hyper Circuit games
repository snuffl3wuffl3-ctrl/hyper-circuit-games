<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <title>Mini Game Hub</title>
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <link rel="stylesheet" href="styles.css" />
</head>
<body>
  <header class="topbar">
    <h1>Mini Game Hub</h1>
    <input id="searchInput" type="text" placeholder="Search games..." />
    <select id="categoryFilter">
      <option value="all">All categories</option>
    </select>
  </header>

  <main>
    <section id="gameGrid" class="game-grid"></section>

    <section id="overlay" class="overlay hidden">
      <div class="overlay-content">
        <button id="closeOverlay" class="close-btn">×</button>
        <iframe id="gameFrame" src="" loading="lazy"></iframe>
      </div>
    </section>
  </main>

  <script src="main.js"></script>
</body>
</html>
